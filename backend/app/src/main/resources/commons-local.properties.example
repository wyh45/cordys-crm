# 本地开发配置模板 — 复制为 commons-local.properties 并填写实际值
logging.config=classpath:logback-spring-local.xml
logging.file.path=/home/wyhubuntu/project/CordysCRM-main/logs/cordys-crm

spring.datasource.url=jdbc:mysql://127.0.0.1:3306/cordys_crm?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=your_db_password

spring.data.redis.host=host.docker.internal
spring.data.redis.port=6379

dify.api.type=chat
dify.api.url=http://your-dify-server/v1
dify.api.key=your_dify_api_key
dify.risk.api.key=your_dify_risk_api_key
dify.api.timeout=120000
dify.sms.api.key=your_dify_sms_api_key

tencentcloud.sms.enabled=false
tencentcloud.sms.secret-id=your_secret_id
tencentcloud.sms.secret-key=your_secret_key
tencentcloud.sms.sms-sdk-app-id=your_app_id
tencentcloud.sms.sign-name=your_sign_name
tencentcloud.sms.invite-template-id=your_template_id

health.api.base-url=http://your-health-api
health.api.app-id=your_app_id
health.api.secret=your_secret
